#!/bin/sh

# Generic wrapper script for Codex CLI hooks using emacsclient.
#
# Usage: codex-hook-wrapper <hook-type> [--emacsclient PATH]
#                           [--socket-name SOCKET | --server-file FILE]
# The hook type is passed as the first argument (e.g., Stop, PreToolUse).

usage() {
    printf 'Usage: codex-hook-wrapper <hook-type> [--emacsclient PATH] [--socket-name SOCKET | --server-file FILE]\n' >&2
}

if [ "$#" -lt 1 ] || [ -z "${1:-}" ]; then
    usage
    exit 1
fi

hook_type=$1
shift

emacsclient_program=${CODEX_EMACSCLIENT:-emacsclient}
socket_name=${CODEX_EMACSCLIENT_SOCKET_NAME:-}
server_file=${CODEX_EMACSCLIENT_SERVER_FILE:-}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --emacsclient)
            if [ "$#" -lt 2 ] || [ -z "$2" ]; then
                usage
                exit 1
            fi
            emacsclient_program=$2
            shift 2
            ;;
        --socket-name)
            if [ "$#" -lt 2 ] || [ -z "$2" ]; then
                usage
                exit 1
            fi
            socket_name=$2
            shift 2
            ;;
        --server-file)
            if [ "$#" -lt 2 ] || [ -z "$2" ]; then
                usage
                exit 1
            fi
            server_file=$2
            shift 2
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

json_file=
response_file=
stderr_file=
cleanup() {
    [ -n "$json_file" ] && rm -f "$json_file"
    [ -n "$response_file" ] && rm -f "$response_file"
    [ -n "$stderr_file" ] && rm -f "$stderr_file"
}
trap cleanup EXIT

dispatch_failure_exit=1
gatekeeping_dispatch_failure_exit=2
dispatch_attempts=${CODEX_HOOK_DISPATCH_ATTEMPTS:-3}
dispatch_retry_delay=${CODEX_HOOK_DISPATCH_RETRY_DELAY:-0.15}

case "$dispatch_attempts" in
    ''|*[!0-9]*)
        dispatch_attempts=3
        ;;
esac
if [ "$dispatch_attempts" -lt 1 ]; then
    dispatch_attempts=1
fi

json_file=$(mktemp "${TMPDIR:-/tmp}/codex-hook-json.XXXXXX") || exit 1
response_file=$(mktemp "${TMPDIR:-/tmp}/codex-hook-response.XXXXXX") || exit 1
stderr_file=$(mktemp "${TMPDIR:-/tmp}/codex-hook-stderr.XXXXXX") || exit 1
chmod 600 "$json_file" "$response_file" "$stderr_file" || exit 1

# An empty positional argument terminates emacsclient's eval-arg batch and
# causes the server to treat subsequent args as separate commands ("Unknown
# command: ..." errors).  Substitute a sentinel that elisp consumers (which
# pass the value to `get-buffer') treat as "no buffer".
buffer_name=${CODEX_BUFFER_NAME:-:none:}
if [ -z "$buffer_name" ]; then
    buffer_name=:none:
fi

cat > "$json_file" || exit 1

fail_for_dispatch_error() {
    message=$(cat "$stderr_file")
    if [ -z "$message" ]; then
        message="emacsclient hook dispatch failed"
    fi
    printf 'codex hook dispatch failed for %s: %s\n' "$hook_type" "$message" >&2
    case "$hook_type" in
        PreToolUse|PermissionRequest)
            # Codex treats exit 2 from gatekeeping hooks as a blocking
            # decision.  If Emacs cannot receive a tool-use or permission hook,
            # fail closed instead of silently allowing the action.
            exit "$gatekeeping_dispatch_failure_exit"
            ;;
        *)
            exit "$dispatch_failure_exit"
            ;;
    esac
}

dispatch_error_is_transient() {
    grep -Eq "can't connect|Connection refused|No socket or alternate editor|No such file or directory" "$stderr_file"
}

run_emacsclient_once() {
    : > "$stderr_file"
    if [ -n "$socket_name" ]; then
        "$emacsclient_program" --socket-name "$socket_name" \
          --eval '(codex-handle-hook-from-emacsclient)' \
          "$hook_type" "$buffer_name" \
          json-file "$json_file" \
          response-file "$response_file" \
          "$@" >/dev/null 2>"$stderr_file"
    elif [ -n "$server_file" ]; then
        "$emacsclient_program" --server-file "$server_file" \
          --eval '(codex-handle-hook-from-emacsclient)' \
          "$hook_type" "$buffer_name" \
          json-file "$json_file" \
          response-file "$response_file" \
          "$@" >/dev/null 2>"$stderr_file"
    else
        "$emacsclient_program" --eval '(codex-handle-hook-from-emacsclient)' \
          "$hook_type" "$buffer_name" \
          json-file "$json_file" \
          response-file "$response_file" \
          "$@" >/dev/null 2>"$stderr_file"
    fi
}

run_emacsclient_with_retry() {
    attempt=1
    while :; do
        if run_emacsclient_once "$@"; then
            return 0
        fi
        if [ "$attempt" -ge "$dispatch_attempts" ] || ! dispatch_error_is_transient; then
            return 1
        fi
        sleep "$dispatch_retry_delay"
        attempt=$((attempt + 1))
    done
}

# Hook JSON travels through a private temp file instead of argv, because hook
# input may contain secrets and can be larger than ARG_MAX.  The json-file and
# response-file labels form the argv protocol parsed by
# `codex-handle-hook-from-emacsclient'.
run_emacsclient_with_retry "$@" || fail_for_dispatch_error

if [ -s "$response_file" ]; then
    cat "$response_file"
fi
