#!/usr/bin/env bash

# Generic wrapper script for Codex CLI hooks using emacsclient
# This script handles the JSON output cleaning that emacsclient requires
#
# Usage: codex-hook-wrapper <hook-type>
# The hook type is passed as the first argument (e.g., 'Stop', 'PreToolUse')

hook_type="$1"
shift  # Remove hook type from arguments to forward the rest

# Read the JSON input from stdin
json_input=$(cat)

# Call emacsclient and get the response
# Pass all hook data as plain string arguments to avoid shell and Elisp interpolation bugs.
response=$(emacsclient --eval '(codex-handle-hook-from-emacsclient)' \
  "$hook_type" "$CODEX_BUFFER_NAME" "$json_input" "$@" 2>/dev/null)

# Check if the response looks like a JSON string (starts and ends with quotes)
if [[ "$response" =~ ^\".*\"$ ]]; then
    # Remove the surrounding quotes that emacsclient adds
    # emacsclient returns strings with quotes like "\"json content\""
    cleaned_response=$(printf '%s' "$response" | sed 's/^"//;s/"$//' | sed 's/\\"/"/g')
    printf '%s\n' "$cleaned_response"
elif [[ "$response" == "nil" || -z "$response" ]]; then
    # If response is nil or empty, don't output anything
    :
else
    # For non-JSON responses, output as-is
    printf '%s\n' "$response"
fi
